words = ['tree', 'sky', 'mountain', 'river', 'cloud', 'sun']

def is_long_word(word):# se define una nueva función is_long_word, donde word es un parametro
    return len(word) > 3# devuelve true o false

long_words = list(filter(is_long_word, words))# lista convierta en lista al iterable de filter, filter es una función que evalua cada parametro que extrae de words con la nueva función creada
print(long_words) #se imprime la nueva lista  

