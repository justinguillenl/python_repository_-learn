languages = ['Spanish', 'English', 'Russian', 'Chinese']

for index, language in enumerate(languages, 1):
    print(f'Index {index} and language {language}') #acá por lo que veo language tomo el valor de una tupla y es impresa, por ello el orden es vertical y no horizontal al imprimirse

developers = ['Naomi', 'Dario', 'Jessica', 'Tom']
ids = [1, 2, 3, 4]

for name, id in zip(developers, ids):# esa coma desenpaqueta al zip ya este devuelve 2 tuplas el name carga los valores de developers y el id carga los valores de ids
    print(f'Name: {name}')
    print(f'ID: {id}')