celsius = [0, 10, 20, 30, 40]

def to_fahrenheit(temp):
    return (temp * 9/5) + 32

fahrenheit = list(map(to_fahrenheit, celsius))# a diferencia de la funcipon filtro que solo toma los valores true, map() transforma toda la anterior lista a otra
print(fahrenheit) # [32.0, 50.0, 68.0, 86.0, 104.0]
