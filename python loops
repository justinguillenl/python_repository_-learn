numbers = [1, 2, 3, 4, 5]

def square(num):# usando una función definida
    return num ** 3 + num** 2 + num + 1

squared_numbers = list(map(square, numbers))# acá el argumento de la función map parece ser square la función definida, luego la lista de numeros como datos a usar la funcion square
print(squared_numbers) 

